{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dlweek.local/schemas/ledger-event.schema.json",
  "title": "LedgerEvent",
  "type": "object",
  "required": [
    "schemaVersion",
    "timestamp",
    "actor",
    "agentRole",
    "actionType",
    "resourcesTouched",
    "prevEventHash",
    "eventHash",
    "scannerSummaryHash",
    "riskCardHash",
    "diffHash",
    "testHashes",
    "approvals"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "minLength": 1 },
    "actor": { "type": "string", "minLength": 1 },
    "agentRole": {
      "type": "string",
      "enum": ["ARCHITECT", "DEVELOPER", "VERIFIER", "OPERATOR", "GOVERNOR"]
    },
    "actionType": { "type": "string", "minLength": 1 },
    "resourcesTouched": {
      "type": "array",
      "items": { "type": "string" }
    },
    "prevEventHash": { "type": "string", "minLength": 1 },
    "eventHash": { "type": "string", "minLength": 1 },
    "scannerSummaryHash": { "type": "string", "minLength": 1 },
    "riskCardHash": { "type": "string", "minLength": 1 },
    "diffHash": { "type": "string", "minLength": 1 },
    "testHashes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["approverId", "approvedAt"],
        "properties": {
          "approverId": { "type": "string", "minLength": 1 },
          "approvedAt": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "breakGlass": {
      "type": "object",
      "required": ["reason", "expiresAt", "postActionReviewRequired"],
      "properties": {
        "reason": { "type": "string", "minLength": 1 },
        "expiresAt": { "type": "string", "minLength": 1 },
        "postActionReviewRequired": { "const": true }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
